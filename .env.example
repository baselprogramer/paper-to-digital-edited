# انسخه إلى .env واملأ القيم

# الدخول (غيّرهما فوراً!)
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
SECRET_KEY=ضع_نصاً_عشوائياً_طويلاً_هنا

# قاعدة البيانات (XAMPP/MySQL)
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mirsad

# الوضع: 1 = تجريبي بلا مفاتيح، 0 = حقيقي
MOCK=1

# المفاتيح (عند MOCK=0)
GEMINI_API_KEY=
EXTRACT_MODEL=gemini-flash-latest

# محرك تعبئة القالب: gemini (يكفي مفتاح واحد) أو claude (أدق — يحتاج مفتاح Anthropic)
STRUCTURE_ENGINE=gemini
# ANTHROPIC_API_KEY=
