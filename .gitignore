# ============================================================
#  من الورق إلى الرقم — .gitignore
# ============================================================

# --- بيئة Python ---
venv/
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# --- Flask / SQLite ---
instance/
*.db
*.sqlite
*.sqlite3

# --- متغيرات البيئة والمفاتيح ---
.env
.env.*
!.env.example

# --- ملفات الرفع والمعالجة ---
uploads/
pages/
tmp/
*.pdf
*.xlsx
*.docx

# --- السجلات ---
*.log
logs/

# --- نظام التشغيل ---
.DS_Store
Thumbs.db
desktop.ini

# --- المحررات وبيئات التطوير ---
.vscode/
.idea/
*.swp
*.swo

# --- نسخ احتياطية ---
*.bak
*.orig
